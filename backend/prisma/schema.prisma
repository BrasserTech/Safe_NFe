generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id                 String       @id @default(cuid())
  legalName          String
  tradeName          String?
  cnpj               String       @unique
  certificateLabel   String?
  certificateExpires DateTime?
  status             CompanyStatus @default(ACTIVE)
  users              User[]
  documents          FiscalDocument[]
  certificates       Certificate[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Certificate {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  type              String   @default("A1")
  holder            String
  document          String
  expiresAt         DateTime
  status            String
  storagePath       String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FiscalDocument {
  id                 String              @id @default(cuid())
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id])
  number             String
  accessKey          String              @unique
  type               DocumentType
  direction          DocumentDirection
  issuerName         String
  issuerCnpj         String
  recipientName      String?
  recipientCnpj      String?
  issuedAt           DateTime
  amount             Decimal             @db.Decimal(12, 2)
  status             DocumentStatus      @default(AUTHORIZED)
  manifestStatus     ManifestStatus      @default(PENDING)
  xmlStoragePath     String?
  danfeStoragePath   String?
  source             String?
  nsu                String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  type      String
  title     String
  detail    String
  metadata  Json?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum CompanyStatus {
  ACTIVE
  PENDING_CERTIFICATE
  INACTIVE
}

enum DocumentType {
  NFE
  NFCE
  NFSE
  CTE
}

enum DocumentDirection {
  INBOUND
  OUTBOUND
}

enum DocumentStatus {
  AUTHORIZED
  CANCELED
  DENIED
  PENDING
}

enum ManifestStatus {
  PENDING
  AWARENESS
  CONFIRMED
  UNKNOWN
  NOT_PERFORMED
}
