generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model app_config {
  chave                       BigInt   @id @default(autoincrement())
  ativo                       Boolean  @default(true)
  identificador               String   @unique(map: "app_config_identificador_uq") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datahoraalt                 DateTime @default(now()) @db.Timestamptz(6)
  nome_sistema                String   @default("Safe NFe") @db.VarChar(120)
  ambiente_padrao             Int      @default(2) @db.SmallInt
  dias_retencao_documentos    Int?
  tamanho_maximo_upload_bytes BigInt   @default(10485760)
  quantidade_maxima_zip       Int      @default(500)
  storage_padrao              String   @default("banco") @db.VarChar(20)
  parametros                  Json     @default("{}")
  datahoracad                 DateTime @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model auditoria {
  chave                  BigInt    @id @default(autoincrement())
  ativo                  Boolean   @default(true)
  identificador          String    @unique(map: "auditoria_identificador_uq") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datahoraalt            DateTime  @default(now()) @db.Timestamptz(6)
  cliente_chave          BigInt?
  empresa_chave          BigInt?
  usuario_chave          BigInt?
  entidade               String    @db.VarChar(80)
  entidade_chave         BigInt?
  entidade_identificador String?   @db.Uuid
  acao                   String    @db.VarChar(40)
  resultado              String    @default("sucesso") @db.VarChar(20)
  descricao              String?
  dados_anteriores       Json?
  dados_novos            Json?
  metadados              Json      @default("{}")
  endereco_ip            String?   @db.Inet
  user_agent             String?
  correlacao_id          String?   @db.Uuid
  dataevento             DateTime  @default(now()) @db.Timestamptz(6)
  datahoracad            DateTime  @default(now()) @db.Timestamptz(6)
  clientes               clientes? @relation(fields: [cliente_chave], references: [chave], onDelete: NoAction, onUpdate: NoAction, map: "auditoria_cliente_fk")
  empresas               empresas? @relation(fields: [empresa_chave], references: [chave], onDelete: NoAction, onUpdate: NoAction, map: "auditoria_empresa_fk")
  usuarios               usuarios? @relation(fields: [usuario_chave], references: [chave], onDelete: NoAction, onUpdate: NoAction, map: "auditoria_usuario_fk")

  @@index([cliente_chave, dataevento(sort: Desc)], map: "auditoria_cliente_data_idx")
  @@index([empresa_chave, dataevento(sort: Desc)], map: "auditoria_empresa_data_idx")
  @@index([entidade, entidade_chave, dataevento(sort: Desc)], map: "auditoria_entidade_idx")
  @@index([usuario_chave, dataevento(sort: Desc)], map: "auditoria_usuario_data_idx")
}

